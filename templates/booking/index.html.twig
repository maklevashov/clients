{% extends 'base.html.twig' %}

{% block title %}Журнал записей{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <style>
        /* Основные стили */
        .app-container {
            max-width: 400px;
            margin: 0 auto;
            background-color: #fff;
            min-height: 100vh;
            position: relative;
            box-shadow: 0 0 20px rgba(0,0,0,0.1);
        }

        /* Header styles */
        .header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            padding: 20px;
            background-color: #fff;
            border-bottom: 1px solid #e0e0e0;
        }

        .date-display {
            display: flex;
            flex-direction: column;
        }

        .time {
            font-size: 24px;
            font-weight: 500;
            color: #333;
        }

        .date {
            font-size: 14px;
            color: #666;
        }

        .user-info {
            display: flex;
            align-items: center;
            gap: 10px;
        }

        .user-name {
            font-size: 18px;
            font-weight: 500;
            color: #333;
        }

        .logout-btn {
            background: none;
            border: none;
            font-size: 20px;
            cursor: pointer;
            color: #999;
            padding: 5px;
        }

        .logout-btn:hover {
            color: #FF6B6B;
        }

        /* Schedule styles */
        .schedule {
            position: relative;
            padding: 20px;
            min-height: 500px;
        }

        .time-slots {
            position: relative;
        }

        .time-slot {
            display: flex;
            align-items: flex-start;
            min-height: 40px;
            border-bottom: 1px solid #f0f0f0;
            position: relative;
        }

        .time-label {
            width: 50px;
            font-size: 12px;
            color: #999;
            padding-top: 5px;
        }

        .slot-content {
            flex: 1;
            height: 40px;
            position: relative;
            cursor: pointer;
        }

        .slot-content:hover {
            background-color: #f9f9f9;
        }

        /* Booking cards */
        .current-bookings {
            position: absolute;
            top: 20px;
            left: 70px;
            right: 20px;
            pointer-events: none;
        }

        .booking-card {
            position: absolute;
            left: 0;
            right: 0;
            background: linear-gradient(135deg, #FFE4E1 0%, #FFD4D1 100%);
            border-left: 4px solid #FF6B6B;
            border-radius: 8px;
            padding: 12px;
            pointer-events: auto;
            box-shadow: 0 2px 8px rgba(0,0,0,0.1);
            transition: transform 0.2s;
        }

        .booking-card {
            height: 120px;
        }

        .booking-card:hover {
            transform: translateX(2px);
        }

        .booking-time {
            font-size: 12px;
            font-weight: 500;
            color: #FF6B6B;
            margin-bottom: 4px;
        }

        .booking-client {
            font-size: 14px;
            font-weight: 500;
            color: #333;
            margin-bottom: 2px;
        }

        .booking-phone {
            font-size: 11px;
            color: #666;
        }

        .delete-booking {
            position: absolute;
            top: 8px;
            right: 8px;
            background: none;
            border: none;
            font-size: 18px;
            color: #999;
            cursor: pointer;
            padding: 0 4px;
            transition: color 0.2s;
        }

        .delete-booking:hover {
            color: #FF6B6B;
        }

        /* Week calendar */
        .week-calendar {
            display: flex;
            justify-content: space-around;
            padding: 15px 10px;
            background-color: #fff;
            border-top: 1px solid #e0e0e0;
            border-bottom: 1px solid #e0e0e0;
            overflow-x: auto;
        }

        .calendar-day {
            display: flex;
            flex-direction: column;
            align-items: center;
            cursor: pointer;
            padding: 8px;
            border-radius: 50%;
            min-width: 50px;
            transition: all 0.2s;
        }

        .calendar-day.active {
            background: linear-gradient(135deg, #007AFF 0%, #0056b3 100%);
            color: white;
            box-shadow: 0 2px 8px rgba(0,122,255,0.3);
        }

        .calendar-day.active .day-name,
        .calendar-day.active .day-number {
            color: white;
        }

        .day-name {
            font-size: 12px;
            color: #666;
            margin-bottom: 4px;
        }

        .day-number {
            font-size: 16px;
            font-weight: 500;
            color: #333;
        }

        /* Bottom navigation */
        .bottom-nav {
            display: flex;
            justify-content: space-around;
            padding: 10px 0;
            background-color: #fff;
            border-top: 1px solid #e0e0e0;
            position: sticky;
            bottom: 0;
        }

        .nav-item {
            display: flex;
            flex-direction: column;
            align-items: center;
            background: none;
            border: none;
            cursor: pointer;
            color: #999;
            font-size: 11px;
            padding: 8px;
            transition: color 0.2s;
        }

        .nav-item.active {
            color: #007AFF;
        }

        .nav-item:hover {
            color: #007AFF;
        }

        .nav-item .icon {
            font-size: 20px;
            margin-bottom: 4px;
        }

        /* Modal styles */
        .modal {
            display: none;
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background-color: rgba(0,0,0,0.5);
            z-index: 1000;
            align-items: flex-end;
        }

        .modal.show {
            display: flex;
        }

        .modal-content {
            position: relative;
            background-color: #fff;
            width: 100%;
            border-radius: 20px 20px 0 0;
            animation: slideUp 0.3s ease;
        }

        @keyframes slideUp {
            from {
                transform: translateY(100%);
                opacity: 0;
            }
            to {
                transform: translateY(0);
                opacity: 1;
            }
        }

        .modal-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            padding: 20px;
            border-bottom: 1px solid #e0e0e0;
        }

        .modal-header h2 {
            font-size: 20px;
            color: #333;
        }

        .close-modal {
            background: none;
            border: none;
            font-size: 28px;
            cursor: pointer;
            color: #999;
            transition: color 0.2s;
        }

        .close-modal:hover {
            color: #333;
        }

        .modal-body {
            padding: 20px;
        }

        .form-group {
            margin-bottom: 20px;
        }

        .form-group label {
            display: block;
            margin-bottom: 8px;
            color: #666;
            font-size: 14px;
            font-weight: 500;
        }

        .form-group input,
        .form-group select,
        .form-group textarea {
            width: 100%;
            padding: 12px;
            border: 1px solid #ddd;
            border-radius: 8px;
            font-size: 16px;
            transition: border-color 0.2s;
        }

        .form-group input:focus,
        .form-group select:focus,
        .form-group textarea:focus {
            outline: none;
            border-color: #007AFF;
        }

        .modal-footer {
            padding: 20px;
            border-top: 1px solid #e0e0e0;
            display: flex;
            gap: 10px;
        }

        .btn-submit {
            flex: 1;
            padding: 14px;
            background: linear-gradient(135deg, #007AFF 0%, #0056b3 100%);
            color: white;
            border: none;
            border-radius: 8px;
            font-size: 16px;
            font-weight: 500;
            cursor: pointer;
            transition: transform 0.2s;
        }

        .btn-submit:hover {
            transform: translateY(-1px);
        }

        .btn-cancel {
            flex: 1;
            padding: 14px;
            background: #f0f0f0;
            color: #666;
            border: none;
            border-radius: 8px;
            font-size: 16px;
            font-weight: 500;
            cursor: pointer;
        }

        /* Loading spinner */
        .loading {
            text-align: center;
            padding: 40px;
            color: #999;
        }

        .no-appointments {
            text-align: center;
            padding: 40px;
            color: #999;
        }

        /* Floating action button */
        .fab-add {
            position: fixed;
            bottom: 80px;
            right: 20px;
            width: 56px;
            height: 56px;
            border-radius: 50%;
            background: linear-gradient(135deg, #007AFF 0%, #0056b3 100%);
            color: white;
            border: none;
            font-size: 24px;
            cursor: pointer;
            box-shadow: 0 4px 12px rgba(0,122,255,0.4);
            z-index: 100;
            transition: transform 0.2s, box-shadow 0.2s;
        }

        .fab-add:hover {
            transform: scale(1.1);
            box-shadow: 0 6px 16px rgba(0,122,255,0.5);
        }

        /* Responsive */
        @media (max-width: 400px) {
            .app-container {
                max-width: 100%;
            }
        }
        /* Модальное окно выбора клиента */
        .selection-modal {
            max-height: 90vh;
            overflow-y: auto;
        }

        .search-client-box {
            margin-bottom: 20px;
        }

        .search-input-wrapper {
            position: relative;
            display: flex;
            align-items: center;
        }

        .search-input-wrapper .search-icon {
            position: absolute;
            left: 15px;
            font-size: 18px;
            color: #999;
        }

        #clientSearchInput {
            width: 100%;
            padding: 14px 40px 14px 45px;
            border: 1px solid #e0e0e0;
            border-radius: 30px;
            font-size: 16px;
            background: #f8f9fa;
            transition: all 0.3s;
        }

        #clientSearchInput:focus {
            outline: none;
            border-color: #007AFF;
            background: white;
            box-shadow: 0 2px 8px rgba(0,122,255,0.1);
        }

        .clear-search {
            position: absolute;
            right: 15px;
            background: none;
            border: none;
            font-size: 24px;
            cursor: pointer;
            color: #999;
            padding: 0;
            width: 30px;
            height: 30px;
            display: flex;
            align-items: center;
            justify-content: center;
            border-radius: 50%;
        }

        .clear-search:hover {
            background: #f0f0f0;
            color: #333;
        }

        /* Результаты поиска */
        .search-results {
            min-height: 150px;
            max-height: 300px;
            overflow-y: auto;
            margin-bottom: 20px;
        }

        .search-loading {
            text-align: center;
            padding: 30px;
            color: #999;
        }

        .no-results {
            text-align: center;
            padding: 30px;
        }

        .no-results-icon {
            font-size: 48px;
            opacity: 0.5;
            display: block;
            margin-bottom: 10px;
        }

        .no-results p {
            color: #999;
            margin-bottom: 15px;
        }

        .create-from-search-btn {
            background: #007AFF;
            color: white;
            border: none;
            padding: 10px 20px;
            border-radius: 25px;
            cursor: pointer;
            font-size: 14px;
        }

        .clients-list-modal {
            max-height: 300px;
            overflow-y: auto;
        }

        .client-result-item {
            display: flex;
            align-items: center;
            justify-content: space-between;
            padding: 12px;
            border-bottom: 1px solid #f0f0f0;
            cursor: pointer;
            transition: background 0.2s;
        }

        .client-result-item:hover {
            background: #f8f9ff;
        }

        .client-result-info {
            flex: 1;
        }

        .client-result-name {
            font-weight: 500;
            color: #333;
            margin-bottom: 4px;
        }

        .client-result-phone {
            font-size: 12px;
            color: #999;
        }

        .client-result-email {
            font-size: 11px;
            color: #ccc;
            margin-top: 2px;
        }

        .select-client-btn {
            background: #007AFF;
            color: white;
            border: none;
            padding: 6px 12px;
            border-radius: 20px;
            font-size: 12px;
            cursor: pointer;
            transition: all 0.2s;
        }

        .select-client-btn:hover {
            background: #0056b3;
            transform: scale(1.02);
        }

        /* Разделитель */
        .divider {
            text-align: center;
            margin: 20px 0;
            position: relative;
        }

        .divider::before {
            content: '';
            position: absolute;
            left: 0;
            top: 50%;
            width: 100%;
            height: 1px;
            background: #e0e0e0;
        }

        .divider span {
            background: white;
            padding: 0 10px;
            position: relative;
            color: #999;
            font-size: 12px;
        }

        .create-new-client-btn {
            width: 100%;
            padding: 12px;
            background: none;
            border: 1px dashed #007AFF;
            border-radius: 30px;
            color: #007AFF;
            font-size: 14px;
            cursor: pointer;
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 8px;
            transition: all 0.3s;
        }

        .create-new-client-btn:hover {
            background: #E8F0FE;
            border-color: #007AFF;
        }

        .create-new-client-btn span {
            font-size: 18px;
            font-weight: bold;
        }

        .required {
            color: #FF3B30;
        }

        /* Анимация загрузки */
        @keyframes pulse {
            0%, 100% {
                opacity: 1;
            }
            50% {
                opacity: 0.5;
            }
        }

        .search-loading {
            animation: pulse 1.5s ease-in-out infinite;
        }

        /* Кастомный селект для выбора клиента */
        .client-select-group {
            position: relative;
        }

        .custom-select {
            position: relative;
            cursor: pointer;
            border: 1px solid #ddd;
            border-radius: 8px;
            background: #fff;
            transition: all 0.3s;
        }

        .custom-select:hover {
            border-color: #007AFF;
        }

        .custom-select-trigger {
            display: flex;
            justify-content: space-between;
            align-items: center;
            padding: 12px;
            font-size: 16px;
            color: #333;
        }

        .custom-select-trigger .arrow {
            color: #999;
            font-size: 12px;
            transition: transform 0.3s;
        }

        .custom-select.open .custom-select-trigger .arrow {
            transform: rotate(180deg);
        }

        #selectedClientDisplay {
            flex: 1;
        }

        #selectedClientDisplay.placeholder {
            color: #999;
        }

        /* Выбранный клиент в форме */
        .selected-client-info {
            background: #E8F0FE;
            border-radius: 8px;
            padding: 8px 12px;
            margin-top: 8px;
            display: flex;
            justify-content: space-between;
            align-items: center;
        }

        .selected-client-name {
            font-weight: 500;
            color: #007AFF;
        }

        .selected-client-phone {
            font-size: 12px;
            color: #666;
        }

        .clear-client-btn {
            background: none;
            border: none;
            color: #999;
            cursor: pointer;
            font-size: 18px;
            padding: 0 4px;
        }

        .clear-client-btn:hover {
            color: #FF3B30;
        }
    </style>
{% endblock %}

{% block body %}
    <div class="app-container">
        <!-- Верхняя панель -->
        <div class="header">
            <div class="date-display">
                <span class="time" id="currentTime">{{ "now"|date("H:i") }}</span>
                <span class="date" id="currentDate">{{ "now"|date("d F")|replace({'January': 'января', 'February': 'февраля', 'March': 'марта', 'April': 'апреля', 'May': 'мая', 'June': 'июня', 'July': 'июля', 'August': 'августа', 'September': 'сентября', 'October': 'октября', 'November': 'ноября', 'December': 'декабря'}) }}</span>
            </div>
            <div class="user-info">
                <span class="user-name">{{ app.user.name }}</span>
                <button class="logout-btn" id="logoutBtn" title="Выйти">🚪</button>
            </div>
        </div>

        <!-- Расписание на день -->
        <div class="schedule">
            <div class="time-slots">
                {% for hour in 7..19 %}
                    <div class="time-slot">
                        <span class="time-label">{{ "%02d:00"|format(hour) }}</span>
                        <div class="slot-content" data-hour="{{ hour }}"></div>
                    </div>
                {% endfor %}
            </div>

            <div class="current-bookings" id="currentBookings">
                <!-- Записи будут загружены через JavaScript -->
            </div>
        </div>

        <!-- Календарь недели -->
        <div class="week-calendar-container">
            <div class="week-navigation">
                <button class="week-nav-btn" id="prevWeekBtn" title="Предыдущая неделя">
                    <span class="arrow">←</span>
                </button>
                <div class="week-info" id="weekInfo"></div>
                <button class="week-nav-btn" id="nextWeekBtn" title="Следующая неделя">
                    <span class="arrow">→</span>
                </button>
            </div>
            <div class="week-calendar" id="weekCalendar">
                <!-- Дни недели будут добавлены через JavaScript -->
            </div>
            <button class="today-btn" id="todayBtn">Сегодня</button>
        </div>

        <!-- Кнопка добавления -->
        <button class="fab-add" id="fabAddBtn">+</button>

        <!-- Нижняя навигация -->
        <div class="bottom-nav">
            <button class="nav-item active" data-page="journal">
                <span class="icon">📋</span>
                <span>Журнал</span>
            </button>
            <button class="nav-item" data-page="schedule">
                <span class="icon">📅</span>
                <span>График</span>
            </button>
            <button class="nav-item" data-page="clients">
                <span class="icon">👥</span>
                <span>Клиенты</span>
            </button>
            <button class="nav-item" data-page="notifications">
                <span class="icon">🔔</span>
                <span>Уведомление</span>
            </button>
            <button class="nav-item" data-page="profile">
                <span class="icon">👤</span>
                <span>Профиль</span>
            </button>
        </div>
    </div>

    <!-- Модальное окно создания записи -->
    <div id="appointmentModal" class="modal">
        <div class="modal-content">
            <div class="modal-header">
                <h2>Новая запись</h2>
                <button class="close-modal" onclick="closeModal('appointmentModal')">&times;</button>
            </div>
            <div class="modal-body">
                <form id="appointmentForm">
                    <!-- Поле выбора клиента с кастомным селектом -->
                    <div class="form-group client-select-group">
                        <label>Клиент <span class="required">*</span></label>
                        <div class="custom-select" id="clientSelectField" onclick="openClientSelectionForAppointment()">
                            <div class="custom-select-trigger">
                                <span id="selectedClientDisplay">Выберите клиента</span>
                                <span class="arrow">▼</span>
                            </div>
                            <input type="hidden" id="selectedClientIdInput">
                        </div>
                    </div>

                    <div class="form-group">
                        <label for="appointmentDate">Дата <span class="required">*</span></label>
                        <input type="date" id="appointmentDate" required>
                    </div>

                    <div class="form-group">
                        <label for="appointmentTime">Время <span class="required">*</span></label>
                        <select id="appointmentTime" required>
                            <option value="07:00">07:00 - 10:00</option>
                            <option value="08:00">08:00 - 11:00</option>
                            <option value="09:00">09:00 - 12:00</option>
                            <option value="10:00">10:00 - 13:00</option>
                            <option value="11:00">11:00 - 14:00</option>
                            <option value="12:00">12:00 - 15:00</option>
                            <option value="13:00">13:00 - 16:00</option>
                            <option value="14:00">14:00 - 17:00</option>
                            <option value="15:00">15:00 - 18:00</option>
                            <option value="16:00">16:00 - 19:00</option>
                            <option value="17:00">17:00 - 20:00</option>
                            <option value="18:00">18:00 - 21:00</option>
                            <option value="19:00">19:00 - 22:00</option>
                        </select>
                    </div>
                </form>
            </div>
            <div class="modal-footer">
                <button class="btn-cancel" onclick="closeModal('appointmentModal')">Отмена</button>
                <button class="btn-submit" onclick="createAppointmentFromModal()">Создать запись</button>
            </div>
        </div>
    </div>
    <!-- Модальное окно выбора клиента -->
    <div id="clientSelectionModal" class="modal">
        <div class="modal-content selection-modal">
            <div class="modal-header">
                <h3>Выбор клиента</h3>
                <button class="close-modal" onclick="closeModal('clientSelectionModal')">&times;</button>
            </div>
            <div class="modal-body">
                <div class="search-client-box">
                    <div class="search-input-wrapper">
                        <span class="search-icon">🔍</span>
                        <input type="text" id="clientSearchInput" placeholder="Введите имя или телефон..." autocomplete="off">
                        <button class="clear-search" id="clearSearchBtn" style="display: none;">×</button>
                    </div>
                </div>
                <div id="searchResults" class="search-results">
                    <div class="search-loading" style="display: none;">Поиск...</div>
                    <div class="no-results" style="display: none;">
                        <span class="no-results-icon">👤</span>
                        <p>Клиент не найден</p>
                        <button class="create-from-search-btn" onclick="openCreateClientFromSelection()">Создать клиента</button>
                    </div>
                    <div id="clientsListModal" class="clients-list-modal"></div>
                </div>
                <div class="divider"><span>или</span></div>
                <button class="create-new-client-btn" onclick="openCreateClientFromSelection()">+ Создать нового клиента</button>
            </div>
        </div>
    </div>

    <!-- Модальное окно создания клиента -->
    <div id="createClientModal" class="modal">
        <div class="modal-content">
            <div class="modal-header">
                <h3>Новый клиент</h3>
                <button class="close-modal" onclick="closeModal('createClientModal')">&times;</button>
            </div>
            <div class="modal-body">
                <form id="quickClientForm">
                    <div class="form-group">
                        <label>Имя <span class="required">*</span></label>
                        <input type="text" id="newClientName" placeholder="Введите имя" required>
                    </div>
                    <div class="form-group">
                        <label>Телефон <span class="required">*</span></label>
                        <input type="tel" id="newClientPhone" placeholder="+7 999 123-45-67" required>
                    </div>
                    <div class="form-group">
                        <label>Email</label>
                        <input type="email" id="newClientEmail" placeholder="email@example.com">
                    </div>
                    <div class="form-group">
                        <label>Примечание</label>
                        <textarea id="newClientNote" rows="2" placeholder="Дополнительная информация"></textarea>
                    </div>
                </form>
            </div>
            <div class="modal-footer">
                <button class="btn-cancel" onclick="closeModal('createClientModal')">Отмена</button>
                <button class="btn-submit" onclick="createAndSelectClient()">Создать и выбрать</button>
            </div>
        </div>
    </div>

    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <script>
        let currentDate = new Date();
        let selectedDate = new Date();
        let currentUser = {{ app.user.id }};
        let pendingClientSelectionCallback = null;

        // Инициализация
        $(document).ready(function() {
            initTimeUpdate();
            renderWeekCalendar();
            loadAppointments(selectedDate);

            // Обработчики событий
            // Обработчик клика по FAB кнопке
            $('#fabAddBtn').click(function() {
                const now = new Date();
                const currentHour = now.getHours();
                const defaultHour = currentHour >= 8 && currentHour <= 18 ? currentHour + 1 : 10;
                const defaultTime = `${defaultHour.toString().padStart(2, '0')}:00`;

                openAppointmentModal(defaultTime);
            });

            $('#logoutBtn').click(function() {
                if (confirm('Вы уверены, что хотите выйти?')) {
                    window.location.href = '/logout';
                }
            });

            // Навигация
            $('.nav-item').click(function() {
                const page = $(this).data('page');
                switch(page) {
                    case 'journal':
                        window.location.href = '/';
                        break;
                    case 'schedule':
                        window.location.href = '/schedule';
                        break;
                    case 'clients':
                        window.location.href = '/clients';
                        break;
                    case 'notifications':
                        window.location.href = '/notifications';
                        break;
                    case 'profile':
                        window.location.href = '/profile';
                        break;
                }
            });

            // Закрытие модальных окон
            $('.close-modal, .close, .close-client').click(function() {
                $('.modal').removeClass('show');
            });

            $(window).click(function(event) {
                if ($(event.target).hasClass('modal')) {
                    $('.modal').removeClass('show');
                }
            });

            // Обработчик клика по слоту времени
            $('.slot-content').click(function() {
                const hour = $(this).data('hour');
                const timeValue = `${hour.toString().padStart(2, '0')}:00`;

                // Открываем окно создания записи
                openAppointmentModal(timeValue);
            });
        });

        // Открытие окна создания записи
        function openAppointmentModal(defaultTime) {
            // Устанавливаем дату
            const currentDate = window.selectedDate || new Date();
            const dateStr = currentDate.toISOString().split('T')[0];
            $('#appointmentDate').val(dateStr);

            // Устанавливаем время, если передано
            if (defaultTime) {
                $('#appointmentTime').val(defaultTime);
            }

            // Сбрасываем выбранного клиента
            resetSelectedClient();

            // Показываем модальное окно
            $('#appointmentModal').addClass('show');
        }

        // Сброс выбранного клиента
        function resetSelectedClient() {
            $('#selectedClientIdInput').val('');
            $('#selectedClientDisplay').text('Выберите клиента').addClass('placeholder');

            // Удаляем блок с информацией о клиенте, если есть
            $('.selected-client-info').remove();
        }

        // Открытие окна выбора клиента из формы создания записи
        function openClientSelectionForAppointment() {
            // Сохраняем callback для возврата
            pendingClientSelectionCallback = function(clientId, clientName, clientPhone) {
                selectClientForAppointmentForm(clientId, clientName, clientPhone);
            };

            // Загружаем список клиентов
            loadClientsForSelection();

            // Очищаем поле поиска
            $('#clientSearchInput').val('');
            $('#searchResults .no-results').hide();
            $('#clearSearchBtn').hide();

            // Показываем модальное окно выбора клиента
            $('#clientSelectionModal').addClass('show');

            // Фокусируемся на поле поиска
            setTimeout(() => {
                $('#clientSearchInput').focus();
            }, 300);
        }

        // Выбор клиента для формы создания записи
        function selectClientForAppointmentForm(clientId, clientName, clientPhone) {
            // Сохраняем ID клиента
            $('#selectedClientIdInput').val(clientId);

            // Обновляем отображение
            $('#selectedClientDisplay').text(clientName).removeClass('placeholder');

            // Добавляем информацию о клиенте
            const clientInfoHtml = `
        <div class="selected-client-info">
            <div>
                <div class="selected-client-name">${escapeHtml(clientName)}</div>
                <div class="selected-client-phone">${escapeHtml(clientPhone)}</div>
            </div>
            <button type="button" class="clear-client-btn" onclick="resetSelectedClient()">✕</button>
        </div>
    `;

            // Удаляем старый блок и добавляем новый
            $('.selected-client-info').remove();
            $('#clientSelectField').after(clientInfoHtml);
        }

        // Создание записи из модального окна
        function createAppointmentFromModal() {
            const clientId = $('#selectedClientIdInput').val();
            const date = $('#appointmentDate').val();
            const time = $('#appointmentTime').val();

            // Валидация
            if (!clientId) {
                alert('Пожалуйста, выберите клиента');
                return;
            }

            if (!date) {
                alert('Пожалуйста, выберите дату');
                return;
            }

            if (!time) {
                alert('Пожалуйста, выберите время');
                return;
            }

            const $submitBtn = $('#appointmentModal .btn-submit');
            const originalText = $submitBtn.text();
            $submitBtn.text('Создание...').prop('disabled', true);

            $.ajax({
                url: '/api/appointments',
                method: 'POST',
                contentType: 'application/json',
                data: JSON.stringify({
                    client_id: clientId,
                    date: date,
                    start_time: time
                }),
                success: function(response) {
                    if (response.success) {
                        closeModal('appointmentModal');

                        // Обновляем расписание
                        const selectedDateObj = new Date(date);
                        loadAppointments(selectedDateObj);

                        // Показываем уведомление
                        showNotification('Запись успешно создана', 'success');

                        // Сбрасываем форму
                        resetSelectedClient();
                    } else {
                        alert('Ошибка: ' + (response.error || 'Неизвестная ошибка'));
                    }
                },
                error: function(xhr) {
                    let errorMsg = 'Не удалось создать запись';
                    if (xhr.responseJSON && xhr.responseJSON.error) {
                        errorMsg = xhr.responseJSON.error;
                    }
                    alert('Ошибка: ' + errorMsg);
                },
                complete: function() {
                    $submitBtn.text(originalText).prop('disabled', false);
                }
            });
        }

        // Функция загрузки клиентов для выбора
        function loadClientsForSelection() {
            $.ajax({
                url: '/api/clients',
                method: 'GET',
                success: function(clients) {
                    displayClientResults(clients);
                },
                error: function() {
                    $('#clientsListModal').html('<div class="no-results"><p>Ошибка загрузки клиентов</p></div>');
                }
            });
        }

        // Отображение результатов клиентов
        function displayClientResults(clients) {
            const $container = $('#clientsListModal');

            if (!clients || clients.length === 0) {
                $container.html(`
            <div class="no-results">
                <span class="no-results-icon">👤</span>
                <p>Нет клиентов</p>
                <button class="create-from-search-btn" onclick="openCreateClientFromSelection()">Создать клиента</button>
            </div>
        `);
                return;
            }

            let html = '';
            clients.forEach(client => {
                html += `
            <div class="client-result-item" data-client-id="${client.id}">
                <div class="client-result-info">
                    <div class="client-result-name">${escapeHtml(client.name)}</div>
                    <div class="client-result-phone">${escapeHtml(client.phone)}</div>
                </div>
                <button class="select-client-btn" onclick="handleClientSelection(${client.id}, '${escapeHtml(client.name)}', '${escapeHtml(client.phone)}')">
                    Выбрать
                </button>
            </div>
        `;
            });

            $container.html(html);
        }

        // Обработка выбора клиента (возврат в форму)
        function handleClientSelection(clientId, clientName, clientPhone) {
            // Закрываем окно выбора клиента
            closeModal('clientSelectionModal');

            // Если есть callback, вызываем его
            if (pendingClientSelectionCallback) {
                pendingClientSelectionCallback(clientId, clientName, clientPhone);
                pendingClientSelectionCallback = null;
            }
        }

        // Поиск клиентов
        function searchClients(query) {
            if (query.length < 2) {
                loadClientsForSelection();
                return;
            }

            $('#searchResults .search-loading').show();
            $('#clientsListModal').hide();

            $.ajax({
                url: `/api/clients/search?q=${encodeURIComponent(query)}`,
                method: 'GET',
                success: function(clients) {
                    $('#searchResults .search-loading').hide();

                    if (clients.length === 0) {
                        $('#clientsListModal').hide();
                        $('#searchResults .no-results').show();
                        $('#createFromSearchBtn').show();
                    } else {
                        $('#searchResults .no-results').hide();
                        displayClientResults(clients);
                        $('#clientsListModal').show();
                    }
                },
                error: function() {
                    $('#searchResults .search-loading').hide();
                    $('#clientsListModal').html('<div class="no-results"><p>Ошибка поиска</p></div>').show();
                }
            });
        }

        // Открыть создание клиента из окна выбора
        function openCreateClientFromSelection() {
            const searchTerm = $('#clientSearchInput').val();

            if (searchTerm && searchTerm.length > 0) {
                if (searchTerm.includes('@')) {
                    $('#newClientEmail').val(searchTerm);
                } else if (searchTerm.match(/[\d\+]/)) {
                    $('#newClientPhone').val(searchTerm);
                } else {
                    $('#newClientName').val(searchTerm);
                }
            }

            $('#createClientModal').addClass('show');
        }

        // Создание клиента и выбор его для записи
        function createAndSelectClient() {
            const name = $('#newClientName').val().trim();
            const phone = $('#newClientPhone').val().trim();
            const email = $('#newClientEmail').val().trim();
            const note = $('#newClientNote').val().trim();

            if (!name || !phone) {
                alert('Пожалуйста, заполните имя и телефон клиента');
                return;
            }

            const $submitBtn = $('#createClientModal .btn-submit');
            const originalText = $submitBtn.text();
            $submitBtn.text('Создание...').prop('disabled', true);

            $.ajax({
                url: '/api/clients',
                method: 'POST',
                contentType: 'application/json',
                data: JSON.stringify({
                    name: name,
                    phone: phone,
                    email: email || null,
                    note: note || null
                }),
                success: function(response) {
                    if (response.success && response.id) {
                        // Закрываем окно создания
                        closeModal('createClientModal');

                        // Очищаем форму
                        $('#newClientName').val('');
                        $('#newClientPhone').val('');
                        $('#newClientEmail').val('');
                        $('#newClientNote').val('');

                        // Выбираем созданного клиента
                        handleClientSelection(response.id, name, phone);

                        showNotification('Клиент успешно создан', 'success');
                    }
                },
                error: function(xhr) {
                    alert('Ошибка при создании клиента: ' + (xhr.responseJSON?.error || 'Неизвестная ошибка'));
                },
                complete: function() {
                    $submitBtn.text(originalText).prop('disabled', false);
                }
            });
        }



        // Обновление времени
        function initTimeUpdate() {
            updateTime();
            setInterval(updateTime, 1000);
        }

        function updateTime() {
            const now = new Date();
            $('#currentTime').text(now.toLocaleTimeString('ru-RU', { hour: '2-digit', minute: '2-digit' }));
        }

        // Рендер календаря недели
        function renderWeekCalendar() {
            const days = ['ПН', 'ВТ', 'СР', 'ЧТ', 'ПТ', 'Сб', 'ВС'];
            const today = new Date();
            const startOfWeek = new Date(today);
            startOfWeek.setDate(today.getDate() - today.getDay() + (today.getDay() === 0 ? -6 : 1));

            let html = '';
            for (let i = 0; i < 7; i++) {
                const date = new Date(startOfWeek);
                date.setDate(startOfWeek.getDate() + i);
                const isToday = date.toDateString() === today.toDateString();
                const isSelected = date.toDateString() === selectedDate.toDateString();

                html += `
                <div class="calendar-day${isSelected ? ' active' : ''}" data-date="${date.toISOString().split('T')[0]}">
                    <span class="day-name">${days[i]}</span>
                    <span class="day-number">${date.getDate()}</span>
                </div>
            `;
            }

            $('#weekCalendar').html(html);

            // Обработчик клика по дню
            $('.calendar-day').click(function() {
                $('.calendar-day').removeClass('active');
                $(this).addClass('active');
                selectedDate = new Date($(this).data('date'));
                loadAppointments(selectedDate);
            });
        }

        // Загрузка записей
        function loadAppointments(date) {
            var dateStr = '';
            if (typeof date !== 'string') {
                dateStr = date.toISOString().split('T')[0];
            } else {
                dateStr = date;
            }

            $.ajax({
                url: `/api/appointments?date=${dateStr}`,
                method: 'GET',
                success: function(appointments) {
                    renderAppointments(appointments);
                },
                error: function() {
                    $('#currentBookings').html('<div class="no-appointments">Ошибка загрузки записей</div>');
                }
            });
        }

        // Отображение записей
        function renderAppointments(appointments) {
            if (appointments.length === 0) {
                $('#currentBookings').html('<div class="no-appointments">Нет записей на этот день</div>');
                return;
            }

            let html = '';
            appointments.forEach(apt => {
                const hour = parseInt(apt.start_time.split(':')[0]);
                const topPosition = (hour - 7) * 40;

                html += `
                <div class="booking-card" data-id="${apt.id}" style="top: ${topPosition}px; height: 120px;">
                    <div class="booking-time">${apt.start_time} - ${apt.end_time}</div>
                    <div class="booking-client">${escapeHtml(apt.client_name)}</div>
                    <div class="booking-phone">${escapeHtml(apt.client_phone)}</div>
                    <button class="delete-booking" onclick="deleteAppointment(${apt.id})">×</button>
                </div>
            `;
            });

            $('#currentBookings').html(html);
        }

        // Показать модальное окно
        function showAppointmentModal() {
            const dateStr = selectedDate.toISOString().split('T')[0];
            $('#appointmentDate').val(dateStr);

            // Открываем выбор клиента вместо прямого выбора
            openClientSelector((client) => {
                // После выбора клиента показываем окно создания записи
                $('#selectedClientId').val(client.id);
                $('#selectedClientName').text(client.name);
                $('#selectedClientPhone').text(client.phone);
                $('#confirmAppointmentModal').addClass('show');
            });
        }

        // Подтверждение записи после выбора клиента
        function confirmAppointment() {
            const clientId = $('#selectedClientId').val();
            const date = $('#appointmentDate').val();
            const time = $('#appointmentTime').val();

            if (!clientId) {
                alert('Клиент не выбран');
                return;
            }

            $.ajax({
                url: '/api/appointments',
                method: 'POST',
                contentType: 'application/json',
                data: JSON.stringify({
                    client_id: clientId,
                    date: date,
                    start_time: time
                }),
                success: function() {
                    closeModal('confirmAppointmentModal');
                    loadAppointments(selectedDate);
                    if (typeof loadAppointmentsForDate === 'function') {
                        loadAppointmentsForDate(selectedDate);
                    }
                },
                error: function(xhr) {
                    alert('Ошибка: ' + (xhr.responseJSON?.error || 'Не удалось создать запись'));
                }
            });
        }

        // Закрыть модальное окно
        window.closeModal = function(modalId) {
            $(`#${modalId}`).removeClass('show');
        };

        // Создание записи
        window.createAppointment = function() {
            const clientId = $('#clientSelect').val();
            const date = $('#appointmentDate').val();
            const time = $('#appointmentTime').val();

            if (!clientId) {
                alert('Выберите клиента');
                return;
            }

            $.ajax({
                url: '/api/appointments',
                method: 'POST',
                contentType: 'application/json',
                data: JSON.stringify({
                    client_id: clientId,
                    date: date,
                    start_time: time
                }),
                success: function() {
                    closeModal('appointmentModal');
                    loadAppointments(selectedDate);
                    $('#appointmentForm')[0].reset();
                },
                error: function(xhr) {
                    alert('Ошибка: ' + (xhr.responseJSON?.error || 'Не удалось создать запись'));
                }
            });
        };

        // Удаление записи
        window.deleteAppointment = function(id) {
            if (confirm('Удалить эту запись?')) {
                $.ajax({
                    url: `/api/appointments/${id}`,
                    method: 'DELETE',
                    success: function() {
                        loadAppointments(selectedDate);
                    },
                    error: function() {
                        alert('Ошибка при удалении записи');
                    }
                });
            }
        };

        // Защита от XSS
        function escapeHtml(text) {
            if (!text) return '';
            const div = document.createElement('div');
            div.textContent = text;
            return div.innerHTML;
        }

        // Обновление при изменении видимости страницы
        document.addEventListener('visibilitychange', function() {
            if (!document.hidden) {
                loadAppointments(selectedDate);
                renderWeekCalendar();
            }
        });
        // Добавить в существующий файл booking.js

        // Класс для обработки свайпов
        class SwipeHandler {
            constructor(element, callbacks) {
                this.element = element;
                this.callbacks = callbacks;
                this.startX = 0;
                this.startY = 0;
                this.distX = 0;
                this.distY = 0;
                this.threshold = 50; // минимальное расстояние для свайпа
                this.restraint = 100; // максимальное вертикальное отклонение
                this.allowedTime = 500; // максимальное время для свайпа в мс
                this.startTime = 0;

                this.init();
            }

            init() {
                this.element.addEventListener('touchstart', this.handleTouchStart.bind(this), false);
                this.element.addEventListener('touchmove', this.handleTouchMove.bind(this), false);
                this.element.addEventListener('touchend', this.handleTouchEnd.bind(this), false);
            }

            handleTouchStart(e) {
                const touch = e.touches[0];
                this.startX = touch.clientX;
                this.startY = touch.clientY;
                this.startTime = Date.now();
            }

            handleTouchMove(e) {
                const touch = e.touches[0];
                this.distX = touch.clientX - this.startX;
                this.distY = touch.clientY - this.startY;

                // Предотвращаем прокрутку страницы при горизонтальном свайпе
                if (Math.abs(this.distX) > Math.abs(this.distY) && Math.abs(this.distX) > 10) {
                    e.preventDefault();
                }
            }

            handleTouchEnd(e) {
                const elapsedTime = Date.now() - this.startTime;

                if (elapsedTime <= this.allowedTime &&
                    Math.abs(this.distX) >= this.threshold &&
                    Math.abs(this.distY) <= this.restraint) {

                    if (this.distX > 0) {
                        // Свайп вправо - предыдущая неделя
                        if (this.callbacks.onSwipeRight) {
                            this.callbacks.onSwipeRight();
                        }
                    } else if (this.distX < 0) {
                        // Свайп влево - следующая неделя
                        if (this.callbacks.onSwipeLeft) {
                            this.callbacks.onSwipeLeft();
                        }
                    }
                }

                // Сброс
                this.distX = 0;
                this.distY = 0;
            }
        }

        // Глобальные переменные для календаря
        let currentWeekOffset = 0;
        let currentWeekDays = [];

        // Инициализация календаря недели со свайпами
        function initWeekCalendarWithSwipe() {
            updateWeekCalendar();

            // Добавляем обработку свайпов для календаря недели
            const weekCalendar = document.querySelector('.week-calendar');
            if (weekCalendar) {
                new SwipeHandler(weekCalendar, {
                    onSwipeLeft: () => {
                        // Свайп влево - следующая неделя
                        currentWeekOffset++;
                        updateWeekCalendar();
                        animateCalendarSlide('left');
                    },
                    onSwipeRight: () => {
                        // Свайп вправо - предыдущая неделя
                        currentWeekOffset--;
                        updateWeekCalendar();
                        animateCalendarSlide('right');
                    }
                });
            }

            // Добавляем поддержку колесика мыши для десктопа
            if (weekCalendar) {
                weekCalendar.addEventListener('wheel', (e) => {
                    if (Math.abs(e.deltaX) > 10) {
                        e.preventDefault();
                        if (e.deltaX > 0) {
                            currentWeekOffset++;
                        } else {
                            currentWeekOffset--;
                        }
                        updateWeekCalendar();
                        animateCalendarSlide(e.deltaX > 0 ? 'left' : 'right');
                    }
                });
            }
        }

        // Обновление календаря недели
        function updateWeekCalendar() {
            const today = new Date();
            const startOfWeek = new Date(today);

            // Смещение недели
            startOfWeek.setDate(today.getDate() - today.getDay() + (today.getDay() === 0 ? -6 : 1) + (currentWeekOffset * 7));

            const days = ['ПН', 'ВТ', 'СР', 'ЧТ', 'ПТ', 'Сб', 'ВС'];
            const weekDays = [];
            let html = '';

            for (let i = 0; i < 7; i++) {
                const date = new Date(startOfWeek);
                date.setDate(startOfWeek.getDate() + i);
                const isToday = date.toDateString() === today.toDateString();
                const isSelected = window.selectedDate && date.toDateString() === window.selectedDate.toDateString();
                const dateStr = formatDate(date);

                weekDays.push(date);

                html += `
            <div class="calendar-day${isSelected ? ' active' : ''} ${isToday ? ' today' : ''}"
                 data-date="${dateStr}"
                 data-index="${i}">
                <span class="day-name">${days[i]}</span>
                <span class="day-number">${date.getDate()}</span>
            </div>
        `;
            }

            currentWeekDays = weekDays;

            const weekCalendar = document.querySelector('.week-calendar');
            if (weekCalendar) {
                weekCalendar.innerHTML = html;

                // Добавляем обработчики кликов
                document.querySelectorAll('.calendar-day').forEach(day => {
                    day.addEventListener('click', () => {
                        const dateStr = day.dataset.date;
                        if (dateStr) {
                            selectDate(new Date(dateStr));
                            loadAppointments(dateStr);
                        }
                    });
                });
            }

            // Обновляем отображение недели
            updateWeekInfo(startOfWeek);
        }

        // Обновление информации о текущей неделе
        function updateWeekInfo(startOfWeek) {
            const endOfWeek = new Date(startOfWeek);
            endOfWeek.setDate(startOfWeek.getDate() + 6);

            const weekInfo = document.getElementById('weekInfo');
            if (weekInfo) {
                const startMonth = startOfWeek.toLocaleString('ru', { month: 'short' });
                const endMonth = endOfWeek.toLocaleString('ru', { month: 'short' });

                if (startMonth === endMonth) {
                    weekInfo.textContent = `${startMonth} ${startOfWeek.getDate()} - ${endOfWeek.getDate()}`;
                } else {
                    weekInfo.textContent = `${startMonth} ${startOfWeek.getDate()} - ${endMonth} ${endOfWeek.getDate()}`;
                }
            }
        }

        // Анимация при свайпе
        function animateCalendarSlide(direction) {
            const container = document.querySelector('.week-calendar');
            if (!container) return;

            container.classList.add('swipe-animation');

            if (direction === 'left') {
                container.classList.add('swipe-left');
            } else if (direction === 'right') {
                container.classList.add('swipe-right');
            }

            setTimeout(() => {
                container.classList.remove('swipe-animation', 'swipe-left', 'swipe-right');
            }, 300);
        }

        // Выбор даты
        function selectDate(date) {
            window.selectedDate = date;

            // Обновляем активный день в календаре
            document.querySelectorAll('.calendar-day').forEach(day => {
                const dayDate = new Date(day.dataset.date);
                if (dayDate.toDateString() === date.toDateString()) {
                    day.classList.add('active');
                } else {
                    day.classList.remove('active');
                }
            });

            // Загружаем записи для выбранной даты
            if (typeof loadAppointmentsForDate === 'function') {
                loadAppointmentsForDate(date);
            }
        }

        // Форматирование даты в YYYY-MM-DD
        function formatDate(date) {
            const year = date.getFullYear();
            const month = String(date.getMonth() + 1).padStart(2, '0');
            const day = String(date.getDate()).padStart(2, '0');
            return `${year}-${month}-${day}`;
        }

        // Переключение на следующую неделю
        function nextWeek() {
            currentWeekOffset++;
            updateWeekCalendar();
            animateCalendarSlide('left');
        }

        // Переключение на предыдущую неделю
        function prevWeek() {
            currentWeekOffset--;
            updateWeekCalendar();
            animateCalendarSlide('right');
        }

        // Возврат к текущей неделе
        function goToCurrentWeek() {
            currentWeekOffset = 0;
            updateWeekCalendar();
            animateCalendarSlide(null);

            // Выбираем текущую дату
            if (typeof selectDate === 'function') {
                selectDate(new Date());
            }
        }

        // Простая версия showNotification без лишних зависимостей
        function showNotification(message, type = 'info') {
            // Удаляем старые уведомления
            $('.notification-toast').remove();

            // Создаем уведомление
            const colors = {
                success: '#34C759',
                error: '#FF3B30',
                warning: '#FF9500',
                info: '#007AFF'
            };

            const $notification = $('<div>')
                .addClass('notification-toast')
                .css({
                    position: 'fixed',
                    bottom: '80px',
                    left: '50%',
                    transform: 'translateX(-50%)',
                    background: colors[type] || colors.info,
                    color: 'white',
                    padding: '10px 20px',
                    borderRadius: '25px',
                    fontSize: '14px',
                    zIndex: 10000,
                    boxShadow: '0 2px 10px rgba(0,0,0,0.2)',
                    whiteSpace: 'nowrap'
                })
                .text(message);

            $('body').append($notification);

            setTimeout(() => {
                $notification.fadeOut(300, function() {
                    $(this).remove();
                });
            }, 3000);
        }

        // Экспорт функций для использования в других файлах
        window.initWeekCalendarWithSwipe = initWeekCalendarWithSwipe;
        window.nextWeek = nextWeek;
        window.prevWeek = prevWeek;
        window.goToCurrentWeek = goToCurrentWeek;
        window.selectDate = selectDate;
    </script>
{% endblock %}