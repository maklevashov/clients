{% extends 'base.html.twig' %}

{% block title %}Журнал записей{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
            -webkit-tap-highlight-color: transparent;
        }

        body {
            font-family: 'Roboto', sans-serif;
            background-color: #f5f5f5;
            overflow: hidden;
            position: fixed;
            width: 100%;
            height: 100%;
        }

        .app-container {
            max-width: 400px;
            margin: 0 auto;
            background-color: #fff;
            height: 100vh;
            height: 100dvh;
            display: flex;
            flex-direction: column;
            position: relative;
            box-shadow: 0 0 20px rgba(0,0,0,0.1);
            overflow: hidden;
        }

        /* Header - фиксированная высота */
        .header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            padding: 12px 16px;
            background-color: #fff;
            border-bottom: 1px solid #e0e0e0;
            flex-shrink: 0;
        }

        .date-display {
            display: flex;
            flex-direction: column;
        }

        .time {
            font-size: 20px;
            font-weight: 500;
            color: #333;
            line-height: 1.2;
        }

        .date {
            font-size: 12px;
            color: #666;
        }

        .user-info {
            display: flex;
            align-items: center;
            gap: 8px;
        }

        .user-name {
            font-size: 14px;
            font-weight: 500;
            color: #333;
        }

        .logout-btn {
            background: none;
            border: none;
            font-size: 18px;
            cursor: pointer;
            color: #999;
            padding: 4px;
        }

        /* Календарь недели - фиксированная высота */
        .week-calendar-container {
            flex-shrink: 0;
            background: #fff;
            padding: 8px 12px;
            border-bottom: 1px solid #e0e0e0;
        }

        .week-navigation {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 8px;
        }

        .week-nav-btn {
            background: none;
            border: none;
            width: 28px;
            height: 28px;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            cursor: pointer;
            color: #007AFF;
            font-size: 16px;
        }

        .week-info {
            font-size: 12px;
            font-weight: 500;
            color: #333;
        }

        .week-calendar {
            display: flex;
            justify-content: space-around;
            gap: 4px;
        }

        .calendar-day {
            flex: 1;
            display: flex;
            flex-direction: column;
            align-items: center;
            padding: 6px 2px;
            border-radius: 10px;
            cursor: pointer;
            transition: all 0.2s;
            background: #fff;
        }

        .calendar-day.active {
            background: linear-gradient(135deg, #007AFF 0%, #5856D6 100%);
            color: white;
        }

        .calendar-day.today {
            border: 1px solid #007AFF;
        }

        .calendar-day.active .day-name,
        .calendar-day.active .day-number {
            color: white;
        }

        .day-name {
            font-size: 10px;
            color: #666;
            margin-bottom: 2px;
        }

        .day-number {
            font-size: 14px;
            font-weight: 500;
            color: #333;
        }

        .today-btn {
            position: absolute;
            bottom: -8px;
            left: 50%;
            transform: translateX(-50%);
            background: #007AFF;
            color: white;
            border: none;
            padding: 4px 12px;
            border-radius: 20px;
            font-size: 10px;
            cursor: pointer;
            white-space: nowrap;
            z-index: 10;
        }

        /* Расписание - основная прокручиваемая область */
        .schedule-wrapper {
            flex: 1;
            overflow-y: auto;
            overflow-x: hidden;
            position: relative;
            -webkit-overflow-scrolling: touch;
        }

        .schedule {
            position: relative;
            min-height: 100%;
            padding-bottom: 60px;
        }

        .time-slots {
            position: relative;
        }

        .time-slot {
            display: flex;
            align-items: flex-start;
            min-height: 56px;
            border-bottom: 1px solid #f0f0f0;
            position: relative;
        }

        .time-label {
            width: 45px;
            font-size: 11px;
            color: #999;
            padding-top: 4px;
            flex-shrink: 0;
        }

        .slot-content {
            flex: 1;
            height: 56px;
            position: relative;
            cursor: pointer;
        }

        .current-bookings {
            position: absolute;
            top: 0;
            left: 45px;
            right: 0;
            pointer-events: none;
        }

        .booking-card {
            position: absolute;
            left: 0;
            right: 0;
            background: linear-gradient(135deg, #FFE4E1 0%, #FFD4D1 100%);
            border-left: 3px solid #FF6B6B;
            border-radius: 6px;
            padding: 8px;
            pointer-events: auto;
            box-shadow: 0 1px 4px rgba(0,0,0,0.1);
        }

        .booking-time {
            font-size: 10px;
            font-weight: 500;
            color: #FF6B6B;
            margin-bottom: 2px;
        }

        .booking-client {
            font-size: 12px;
            font-weight: 500;
            color: #333;
            white-space: nowrap;
            overflow: hidden;
            text-overflow: ellipsis;
        }

        .booking-phone {
            font-size: 9px;
            color: #666;
            white-space: nowrap;
            overflow: hidden;
            text-overflow: ellipsis;
        }

        .delete-booking {
            position: absolute;
            top: 4px;
            right: 4px;
            background: none;
            border: none;
            font-size: 16px;
            color: #999;
            cursor: pointer;
            padding: 0 4px;
        }

        .no-appointments {
            text-align: center;
            padding: 40px 20px;
            color: #999;
            font-size: 14px;
        }

        /* Нижняя навигация - фиксированная высота */
        .bottom-nav {
            display: flex;
            justify-content: space-around;
            padding: 6px 0;
            background-color: #fff;
            border-top: 1px solid #e0e0e0;
            flex-shrink: 0;
        }

        .nav-item {
            display: flex;
            flex-direction: column;
            align-items: center;
            background: none;
            border: none;
            cursor: pointer;
            color: #999;
            font-size: 10px;
            padding: 4px;
        }

        .nav-item.active {
            color: #007AFF;
        }

        .nav-item .icon {
            font-size: 18px;
            margin-bottom: 2px;
        }

        /* FAB кнопка */
        .fab-add {
            position: absolute;
            bottom: 70px;
            right: 16px;
            width: 48px;
            height: 48px;
            border-radius: 50%;
            background: linear-gradient(135deg, #007AFF 0%, #0056b3 100%);
            color: white;
            border: none;
            font-size: 20px;
            cursor: pointer;
            box-shadow: 0 2px 8px rgba(0,122,255,0.4);
            z-index: 20;
            display: flex;
            align-items: center;
            justify-content: center;
        }

        /* Модальные окна */
        .modal {
            display: none;
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background-color: rgba(0,0,0,0.5);
            z-index: 1000;
            align-items: flex-end;
        }

        .modal.show {
            display: flex;
        }

        .modal-content {
            background-color: #fff;
            width: 100%;
            border-radius: 20px 20px 0 0;
            max-height: 80vh;
            overflow-y: auto;
        }

        .modal-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            padding: 16px;
            border-bottom: 1px solid #e0e0e0;
            position: sticky;
            top: 0;
            background: white;
            z-index: 10;
        }

        .modal-header h2 {
            font-size: 18px;
            color: #333;
        }

        .close-modal {
            background: none;
            border: none;
            font-size: 24px;
            cursor: pointer;
            color: #999;
        }

        .modal-body {
            padding: 16px;
        }

        .form-group {
            margin-bottom: 16px;
        }

        .form-group label {
            display: block;
            margin-bottom: 6px;
            color: #666;
            font-size: 13px;
        }

        .form-group input,
        .form-group select {
            width: 100%;
            padding: 10px;
            border: 1px solid #ddd;
            border-radius: 8px;
            font-size: 14px;
        }

        .modal-footer {
            padding: 16px;
            border-top: 1px solid #e0e0e0;
            display: flex;
            gap: 10px;
            position: sticky;
            bottom: 0;
            background: white;
        }

        .btn-submit {
            flex: 1;
            padding: 12px;
            background: #007AFF;
            color: white;
            border: none;
            border-radius: 8px;
            font-size: 14px;
            font-weight: 500;
            cursor: pointer;
        }

        .btn-cancel {
            flex: 1;
            padding: 12px;
            background: #f0f0f0;
            color: #666;
            border: none;
            border-radius: 8px;
            font-size: 14px;
            cursor: pointer;
        }

        /* Скрытие скроллбара для WebKit */
        .schedule-wrapper::-webkit-scrollbar {
            width: 0;
            background: transparent;
        }

        /* Адаптация для очень маленьких экранов */
        @media (max-width: 380px) {
            .time-label {
                width: 40px;
                font-size: 10px;
            }

            .current-bookings {
                left: 40px;
            }

            .booking-client {
                font-size: 11px;
            }

            .calendar-day {
                padding: 4px 2px;
            }

            .day-number {
                font-size: 12px;
            }

            .day-name {
                font-size: 9px;
            }
        }
    </style>
{% endblock %}

{% block body %}
    <div class="app-container">
        <!-- Верхняя панель -->
        <div class="header">
            <div class="date-display">
                <span class="time" id="currentTime">{{ "now"|date("H:i") }}</span>
                <span class="date" id="currentDate">{{ "now"|date("d F")|replace({'January': 'января', 'February': 'февраля', 'March': 'марта', 'April': 'апреля', 'May': 'мая', 'June': 'июня', 'July': 'июля', 'August': 'августа', 'September': 'сентября', 'October': 'октября', 'November': 'ноября', 'December': 'декабря'}) }}</span>
            </div>
            <div class="user-info">
                <span class="user-name">{{ app.user.name }}</span>
                <button class="logout-btn" id="logoutBtn" title="Выйти">🚪</button>
            </div>
        </div>

        <!-- Календарь недели -->
        <div class="week-calendar-container">
            <div class="week-navigation">
                <button class="week-nav-btn" id="prevWeekBtn">←</button>
                <div class="week-info" id="weekInfo"></div>
                <button class="week-nav-btn" id="nextWeekBtn">→</button>
            </div>
            <div class="week-calendar" id="weekCalendar"></div>
            <button class="today-btn" id="todayBtn">Сегодня</button>
        </div>

        <!-- Расписание (прокручиваемая область) -->
        <div class="schedule-wrapper">
            <div class="schedule">
                <div class="time-slots" id="timeSlotsContainer">
                    <!-- Слоты времени будут сгенерированы через JS -->
                </div>
                <div class="current-bookings" id="currentBookings"></div>
            </div>
        </div>

        <!-- Кнопка добавления -->
        <button class="fab-add" id="fabAddBtn">+</button>

        <!-- Нижняя навигация -->
        <div class="bottom-nav">
            <button class="nav-item active" data-page="journal">
                <span class="icon">📋</span>
                <span>Журнал</span>
            </button>
            <button class="nav-item" data-page="schedule">
                <span class="icon">📅</span>
                <span>График</span>
            </button>
            <button class="nav-item" data-page="clients">
                <span class="icon">👥</span>
                <span>Клиенты</span>
            </button>
            <button class="nav-item" data-page="notifications">
                <span class="icon">🔔</span>
                <span>Уведомление</span>
            </button>
            <button class="nav-item" data-page="profile">
                <span class="icon">👤</span>
                <span>Профиль</span>
            </button>
        </div>
    </div>

    <!-- Модальное окно для создания записи -->
    <div id="appointmentModal" class="modal">
        <div class="modal-content">
            <div class="modal-header">
                <h2>Новая запись</h2>
                <button class="close-modal" onclick="closeModal('appointmentModal')">&times;</button>
            </div>
            <div class="modal-body">
                <form id="appointmentForm">
                    <div class="form-group">
                        <label for="clientSelect">Клиент:</label>
                        <select id="clientSelect" required>
                            <option value="">Выберите клиента</option>
                            {% for client in clients %}
                                <option value="{{ client.id }}">{{ client.name }} - {{ client.phone }}</option>
                            {% endfor %}
                        </select>
                    </div>
                    <div class="form-group">
                        <label for="appointmentDate">Дата:</label>
                        <input type="date" id="appointmentDate" required>
                    </div>
                    <div class="form-group">
                        <label for="appointmentTime">Время:</label>
                        <select id="appointmentTime" required>
                            <option value="08:00">08:00 - 11:00</option>
                            <option value="09:00">09:00 - 12:00</option>
                            <option value="10:00">10:00 - 13:00</option>
                            <option value="11:00">11:00 - 14:00</option>
                            <option value="12:00">12:00 - 15:00</option>
                            <option value="13:00">13:00 - 16:00</option>
                            <option value="14:00">14:00 - 17:00</option>
                            <option value="15:00">15:00 - 18:00</option>
                            <option value="16:00">16:00 - 19:00</option>
                            <option value="17:00">17:00 - 20:00</option>
                            <option value="18:00">18:00 - 21:00</option>
                            <option value="19:00">19:00 - 22:00</option>
                        </select>
                    </div>
                </form>
            </div>
            <div class="modal-footer">
                <button class="btn-cancel" onclick="closeModal('appointmentModal')">Отмена</button>
                <button class="btn-submit" onclick="createAppointment()">Создать</button>
            </div>
        </div>
    </div>
{% endblock %}

    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <script>
        let currentDate = new Date();
        let selectedDate = new Date();
        let currentUser = {{ app.user.id }};

        // Инициализация
        $(document).ready(function() {
            initTimeUpdate();
            renderWeekCalendar();
            loadAppointments(selectedDate);

            // Обработчики событий
            $('#fabAddBtn').click(function() {
                showAppointmentModal();
            });

            $('#logoutBtn').click(function() {
                if (confirm('Вы уверены, что хотите выйти?')) {
                    window.location.href = '/logout';
                }
            });

            // Навигация
            $('.nav-item').click(function() {
                const page = $(this).data('page');
                switch(page) {
                    case 'journal':
                        window.location.href = '/';
                        break;
                    case 'schedule':
                        window.location.href = '/schedule';
                        break;
                    case 'clients':
                        window.location.href = '/clients';
                        break;
                    case 'notifications':
                        window.location.href = '/notifications';
                        break;
                    case 'profile':
                        window.location.href = '/profile';
                        break;
                }
            });

            // Клик по временному слоту
            $(document).on('click', '.slot-content', function() {
                const hour = $(this).data('hour');
                $('#appointmentTime').val(`${hour.toString().padStart(2, '0')}:00`);
                showAppointmentModal();
            });
        });

        // Обновление времени
        function initTimeUpdate() {
            updateTime();
            setInterval(updateTime, 1000);
        }

        function updateTime() {
            const now = new Date();
            $('#currentTime').text(now.toLocaleTimeString('ru-RU', { hour: '2-digit', minute: '2-digit' }));
        }

        // Рендер календаря недели
        function renderWeekCalendar() {
            const days = ['ПН', 'ВТ', 'СР', 'ЧТ', 'ПТ', 'Сб', 'ВС'];
            const today = new Date();
            const startOfWeek = new Date(today);
            startOfWeek.setDate(today.getDate() - today.getDay() + (today.getDay() === 0 ? -6 : 1));

            let html = '';
            for (let i = 0; i < 7; i++) {
                const date = new Date(startOfWeek);
                date.setDate(startOfWeek.getDate() + i);
                const isToday = date.toDateString() === today.toDateString();
                const isSelected = date.toDateString() === selectedDate.toDateString();

                html += `
                <div class="calendar-day${isSelected ? ' active' : ''}" data-date="${date.toISOString().split('T')[0]}">
                    <span class="day-name">${days[i]}</span>
                    <span class="day-number">${date.getDate()}</span>
                </div>
            `;
            }

            $('#weekCalendar').html(html);

            // Обработчик клика по дню
            $('.calendar-day').click(function() {
                $('.calendar-day').removeClass('active');
                $(this).addClass('active');
                selectedDate = new Date($(this).data('date'));
                loadAppointments(selectedDate);
            });
        }

        // Загрузка записей
        function loadAppointments(date) {
            var dateStr = '';
            if (typeof date !== 'string') {
                dateStr = date.toISOString().split('T')[0];
            } else {
                dateStr = date;
            }

            $.ajax({
                url: `/api/appointments?date=${dateStr}`,
                method: 'GET',
                success: function(appointments) {
                    renderAppointments(appointments);
                },
                error: function() {
                    $('#currentBookings').html('<div class="no-appointments">Ошибка загрузки записей</div>');
                }
            });
        }

        // Отображение записей
        function renderAppointments(appointments) {
            if (appointments.length === 0) {
                $('#currentBookings').html('<div class="no-appointments">Нет записей на этот день</div>');
                return;
            }

            let html = '';
            appointments.forEach(apt => {
                const hour = parseInt(apt.start_time.split(':')[0]);
                const topPosition = (hour - 8) * 60;

                html += `
                <div class="booking-card" data-id="${apt.id}" style="top: ${topPosition}px; height: 180px;">
                    <div class="booking-time">${apt.start_time} - ${apt.end_time}</div>
                    <div class="booking-client">${escapeHtml(apt.client_name)}</div>
                    <div class="booking-phone">${escapeHtml(apt.client_phone)}</div>
                    <button class="delete-booking" onclick="deleteAppointment(${apt.id})">×</button>
                </div>
            `;
            });

            $('#currentBookings').html(html);
        }

        // Показать модальное окно
        function showAppointmentModal() {
            const dateStr = selectedDate.toISOString().split('T')[0];
            $('#appointmentDate').val(dateStr);

            // Открываем выбор клиента вместо прямого выбора
            openClientSelector((client) => {
                // После выбора клиента показываем окно создания записи
                $('#selectedClientId').val(client.id);
                $('#selectedClientName').text(client.name);
                $('#selectedClientPhone').text(client.phone);
                $('#confirmAppointmentModal').addClass('show');
            });
        }

        // Подтверждение записи после выбора клиента
        function confirmAppointment() {
            const clientId = $('#selectedClientId').val();
            const date = $('#appointmentDate').val();
            const time = $('#appointmentTime').val();

            if (!clientId) {
                alert('Клиент не выбран');
                return;
            }

            $.ajax({
                url: '/api/appointments',
                method: 'POST',
                contentType: 'application/json',
                data: JSON.stringify({
                    client_id: clientId,
                    date: date,
                    start_time: time
                }),
                success: function() {
                    closeModal('confirmAppointmentModal');
                    loadAppointments(selectedDate);
                    if (typeof loadAppointmentsForDate === 'function') {
                        loadAppointmentsForDate(selectedDate);
                    }
                },
                error: function(xhr) {
                    alert('Ошибка: ' + (xhr.responseJSON?.error || 'Не удалось создать запись'));
                }
            });
        }

        // Закрыть модальное окно
        window.closeModal = function(modalId) {
            $(`#${modalId}`).removeClass('show');
        };

        // Создание записи
        window.createAppointment = function() {
            const clientId = $('#clientSelect').val();
            const date = $('#appointmentDate').val();
            const time = $('#appointmentTime').val();

            if (!clientId) {
                alert('Выберите клиента');
                return;
            }

            $.ajax({
                url: '/api/appointments',
                method: 'POST',
                contentType: 'application/json',
                data: JSON.stringify({
                    client_id: clientId,
                    date: date,
                    start_time: time
                }),
                success: function() {
                    closeModal('appointmentModal');
                    loadAppointments(selectedDate);
                    $('#appointmentForm')[0].reset();
                },
                error: function(xhr) {
                    alert('Ошибка: ' + (xhr.responseJSON?.error || 'Не удалось создать запись'));
                }
            });
        };

        // Удаление записи
        window.deleteAppointment = function(id) {
            if (confirm('Удалить эту запись?')) {
                $.ajax({
                    url: `/api/appointments/${id}`,
                    method: 'DELETE',
                    success: function() {
                        loadAppointments(selectedDate);
                    },
                    error: function() {
                        alert('Ошибка при удалении записи');
                    }
                });
            }
        };

        // Защита от XSS
        function escapeHtml(text) {
            if (!text) return '';
            const div = document.createElement('div');
            div.textContent = text;
            return div.innerHTML;
        }

        // Обновление при изменении видимости страницы
        document.addEventListener('visibilitychange', function() {
            if (!document.hidden) {
                loadAppointments(selectedDate);
                renderWeekCalendar();
            }
        });
        // Добавить в существующий файл booking.js

        // Класс для обработки свайпов
        class SwipeHandler {
            constructor(element, callbacks) {
                this.element = element;
                this.callbacks = callbacks;
                this.startX = 0;
                this.startY = 0;
                this.distX = 0;
                this.distY = 0;
                this.threshold = 50; // минимальное расстояние для свайпа
                this.restraint = 100; // максимальное вертикальное отклонение
                this.allowedTime = 500; // максимальное время для свайпа в мс
                this.startTime = 0;

                this.init();
            }

            init() {
                this.element.addEventListener('touchstart', this.handleTouchStart.bind(this), false);
                this.element.addEventListener('touchmove', this.handleTouchMove.bind(this), false);
                this.element.addEventListener('touchend', this.handleTouchEnd.bind(this), false);
            }

            handleTouchStart(e) {
                const touch = e.touches[0];
                this.startX = touch.clientX;
                this.startY = touch.clientY;
                this.startTime = Date.now();
            }

            handleTouchMove(e) {
                const touch = e.touches[0];
                this.distX = touch.clientX - this.startX;
                this.distY = touch.clientY - this.startY;

                // Предотвращаем прокрутку страницы при горизонтальном свайпе
                if (Math.abs(this.distX) > Math.abs(this.distY) && Math.abs(this.distX) > 10) {
                    e.preventDefault();
                }
            }

            handleTouchEnd(e) {
                const elapsedTime = Date.now() - this.startTime;

                if (elapsedTime <= this.allowedTime &&
                    Math.abs(this.distX) >= this.threshold &&
                    Math.abs(this.distY) <= this.restraint) {

                    if (this.distX > 0) {
                        // Свайп вправо - предыдущая неделя
                        if (this.callbacks.onSwipeRight) {
                            this.callbacks.onSwipeRight();
                        }
                    } else if (this.distX < 0) {
                        // Свайп влево - следующая неделя
                        if (this.callbacks.onSwipeLeft) {
                            this.callbacks.onSwipeLeft();
                        }
                    }
                }

                // Сброс
                this.distX = 0;
                this.distY = 0;
            }
        }

        // Глобальные переменные для календаря
        let currentWeekOffset = 0;
        let currentWeekDays = [];

        // Инициализация календаря недели со свайпами
        function initWeekCalendarWithSwipe() {
            updateWeekCalendar();

            // Добавляем обработку свайпов для календаря недели
            const weekCalendar = document.querySelector('.week-calendar');
            if (weekCalendar) {
                new SwipeHandler(weekCalendar, {
                    onSwipeLeft: () => {
                        // Свайп влево - следующая неделя
                        currentWeekOffset++;
                        updateWeekCalendar();
                        animateCalendarSlide('left');
                    },
                    onSwipeRight: () => {
                        // Свайп вправо - предыдущая неделя
                        currentWeekOffset--;
                        updateWeekCalendar();
                        animateCalendarSlide('right');
                    }
                });
            }

            // Добавляем поддержку колесика мыши для десктопа
            if (weekCalendar) {
                weekCalendar.addEventListener('wheel', (e) => {
                    if (Math.abs(e.deltaX) > 10) {
                        e.preventDefault();
                        if (e.deltaX > 0) {
                            currentWeekOffset++;
                        } else {
                            currentWeekOffset--;
                        }
                        updateWeekCalendar();
                        animateCalendarSlide(e.deltaX > 0 ? 'left' : 'right');
                    }
                });
            }
        }

        // Обновление календаря недели
        function updateWeekCalendar() {
            const today = new Date();
            const startOfWeek = new Date(today);

            // Смещение недели
            startOfWeek.setDate(today.getDate() - today.getDay() + (today.getDay() === 0 ? -6 : 1) + (currentWeekOffset * 7));

            const days = ['ПН', 'ВТ', 'СР', 'ЧТ', 'ПТ', 'Сб', 'ВС'];
            const weekDays = [];
            let html = '';

            for (let i = 0; i < 7; i++) {
                const date = new Date(startOfWeek);
                date.setDate(startOfWeek.getDate() + i);
                const isToday = date.toDateString() === today.toDateString();
                const isSelected = window.selectedDate && date.toDateString() === window.selectedDate.toDateString();
                const dateStr = formatDate(date);

                weekDays.push(date);

                html += `
            <div class="calendar-day${isSelected ? ' active' : ''} ${isToday ? ' today' : ''}"
                 data-date="${dateStr}"
                 data-index="${i}">
                <span class="day-name">${days[i]}</span>
                <span class="day-number">${date.getDate()}</span>
            </div>
        `;
            }

            currentWeekDays = weekDays;

            const weekCalendar = document.querySelector('.week-calendar');
            if (weekCalendar) {
                weekCalendar.innerHTML = html;

                // Добавляем обработчики кликов
                document.querySelectorAll('.calendar-day').forEach(day => {
                    day.addEventListener('click', () => {
                        const dateStr = day.dataset.date;
                        if (dateStr) {
                            selectDate(new Date(dateStr));
                            loadAppointments(dateStr);
                        }
                    });
                });
            }

            // Обновляем отображение недели
            updateWeekInfo(startOfWeek);
        }

        // Обновление информации о текущей неделе
        function updateWeekInfo(startOfWeek) {
            const endOfWeek = new Date(startOfWeek);
            endOfWeek.setDate(startOfWeek.getDate() + 6);

            const weekInfo = document.getElementById('weekInfo');
            if (weekInfo) {
                const startMonth = startOfWeek.toLocaleString('ru', { month: 'short' });
                const endMonth = endOfWeek.toLocaleString('ru', { month: 'short' });

                if (startMonth === endMonth) {
                    weekInfo.textContent = `${startMonth} ${startOfWeek.getDate()} - ${endOfWeek.getDate()}`;
                } else {
                    weekInfo.textContent = `${startMonth} ${startOfWeek.getDate()} - ${endMonth} ${endOfWeek.getDate()}`;
                }
            }
        }

        // Анимация при свайпе
        function animateCalendarSlide(direction) {
            const container = document.querySelector('.week-calendar');
            if (!container) return;

            container.classList.add('swipe-animation');

            if (direction === 'left') {
                container.classList.add('swipe-left');
            } else if (direction === 'right') {
                container.classList.add('swipe-right');
            }

            setTimeout(() => {
                container.classList.remove('swipe-animation', 'swipe-left', 'swipe-right');
            }, 300);
        }

        // Выбор даты
        function selectDate(date) {
            window.selectedDate = date;

            // Обновляем активный день в календаре
            document.querySelectorAll('.calendar-day').forEach(day => {
                const dayDate = new Date(day.dataset.date);
                if (dayDate.toDateString() === date.toDateString()) {
                    day.classList.add('active');
                } else {
                    day.classList.remove('active');
                }
            });

            // Загружаем записи для выбранной даты
            if (typeof loadAppointmentsForDate === 'function') {
                loadAppointmentsForDate(date);
            }
        }

        // Форматирование даты в YYYY-MM-DD
        function formatDate(date) {
            const year = date.getFullYear();
            const month = String(date.getMonth() + 1).padStart(2, '0');
            const day = String(date.getDate()).padStart(2, '0');
            return `${year}-${month}-${day}`;
        }

        // Переключение на следующую неделю
        function nextWeek() {
            currentWeekOffset++;
            updateWeekCalendar();
            animateCalendarSlide('left');
        }

        // Переключение на предыдущую неделю
        function prevWeek() {
            currentWeekOffset--;
            updateWeekCalendar();
            animateCalendarSlide('right');
        }

        // Возврат к текущей неделе
        function goToCurrentWeek() {
            currentWeekOffset = 0;
            updateWeekCalendar();
            animateCalendarSlide(null);

            // Выбираем текущую дату
            if (typeof selectDate === 'function') {
                selectDate(new Date());
            }
        }

        // Экспорт функций для использования в других файлах
        window.initWeekCalendarWithSwipe = initWeekCalendarWithSwipe;
        window.nextWeek = nextWeek;
        window.prevWeek = prevWeek;
        window.goToCurrentWeek = goToCurrentWeek;
        window.selectDate = selectDate;
    </script>
{% endblock %}