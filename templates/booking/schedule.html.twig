{% extends 'base.html.twig' %}

{% block title %}График записей{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <style>
        /* Календарь */
        .calendar-container {
            background: #fff;
            min-height: 100vh;
            padding-bottom: 70px;
        }

        .calendar-header {
            padding: 20px;
            background: #fff;
            border-bottom: 1px solid #e0e0e0;
        }

        .date-picker-header {
            display: flex;
            justify-content: space-between;
            align-items: baseline;
            margin-bottom: 15px;
        }

        .selected-date {
            font-size: 18px;
            font-weight: 500;
            color: #333;
        }

        .view-all-btn {
            background: none;
            border: none;
            color: #007AFF;
            font-size: 14px;
            cursor: pointer;
        }

        /* Навигация по месяцам */
        .month-navigation {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 20px;
        }

        .month-nav-btn {
            background: none;
            border: none;
            font-size: 20px;
            cursor: pointer;
            color: #007AFF;
            padding: 8px 12px;
        }

        .current-month {
            font-size: 18px;
            font-weight: 500;
            color: #333;
        }

        /* Дни недели */
        .weekdays {
            display: grid;
            grid-template-columns: repeat(7, 1fr);
            text-align: center;
            padding: 10px 0;
            background: #f8f8f8;
            border-radius: 8px;
            margin-bottom: 10px;
        }

        .weekday {
            font-size: 14px;
            color: #666;
            font-weight: 500;
        }

        /* Календарная сетка */
        .calendar-grid {
            display: grid;
            grid-template-columns: repeat(7, 1fr);
            gap: 4px;
            margin-bottom: 30px;
        }

        .calendar-day-cell {
            aspect-ratio: 1;
            padding: 8px;
            text-align: center;
            position: relative;
            cursor: pointer;
            border-radius: 8px;
            transition: all 0.2s;
            background: #fff;
        }

        .calendar-day-cell:hover {
            background: #f5f5f5;
        }

        .calendar-day-cell.other-month {
            color: #ccc;
        }

        .calendar-day-cell.today {
            background: #007AFF;
            color: white;
        }

        .calendar-day-cell.selected {
            background: #007AFF;
            color: white;
            box-shadow: 0 2px 8px rgba(0,122,255,0.3);
        }

        .calendar-day-cell.has-appointments {
            font-weight: 600;
            position: relative;
        }

        .calendar-day-cell.has-appointments::after {
            content: '';
            position: absolute;
            bottom: 4px;
            left: 50%;
            transform: translateX(-50%);
            width: 4px;
            height: 4px;
            background: #FF6B6B;
            border-radius: 50%;
        }

        .calendar-day-cell.today.has-appointments::after,
        .calendar-day-cell.selected.has-appointments::after {
            background: white;
        }

        .day-number {
            font-size: 16px;
            font-weight: 500;
        }

        /* Блок с записями на выбранную дату */
        .appointments-panel {
            background: #fff;
            border-top: 1px solid #e0e0e0;
            padding: 20px;
            margin-top: 20px;
        }

        .appointments-panel-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 15px;
        }

        .appointments-panel-header h3 {
            font-size: 16px;
            color: #333;
        }

        .add-appointment-btn {
            background: #007AFF;
            color: white;
            border: none;
            padding: 6px 12px;
            border-radius: 20px;
            font-size: 12px;
            cursor: pointer;
        }

        .appointments-list {
            max-height: 400px;
            overflow-y: auto;
        }

        .appointment-item {
            display: flex;
            align-items: center;
            padding: 12px;
            background: #f9f9f9;
            border-radius: 8px;
            margin-bottom: 8px;
            position: relative;
        }

        .appointment-time {
            min-width: 70px;
            font-weight: 500;
            color: #FF6B6B;
            font-size: 14px;
        }

        .appointment-info {
            flex: 1;
            margin-left: 12px;
        }

        .appointment-client {
            font-size: 16px;
            font-weight: 500;
            color: #333;
        }

        .appointment-phone {
            font-size: 12px;
            color: #999;
            margin-top: 2px;
        }

        .delete-appointment {
            background: none;
            border: none;
            color: #999;
            font-size: 18px;
            cursor: pointer;
            padding: 4px 8px;
        }

        .delete-appointment:hover {
            color: #FF6B6B;
        }

        .no-appointments {
            text-align: center;
            padding: 40px;
            color: #999;
        }

        /* Кнопка добавления клиента */
        .fab-add-client {
            position: fixed;
            bottom: 80px;
            right: 20px;
            width: 56px;
            height: 56px;
            border-radius: 50%;
            background: #007AFF;
            color: white;
            border: none;
            font-size: 24px;
            cursor: pointer;
            box-shadow: 0 4px 12px rgba(0,122,255,0.4);
            z-index: 100;
            transition: transform 0.2s;
        }

        .fab-add-client:hover {
            transform: scale(1.1);
        }

        /* Модальное окно */
        .modal {
            display: none;
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background: rgba(0,0,0,0.5);
            z-index: 1000;
        }

        .modal-content {
            position: absolute;
            bottom: 0;
            left: 0;
            right: 0;
            background: white;
            border-radius: 20px 20px 0 0;
            padding: 20px;
            animation: slideUp 0.3s ease;
        }

        @keyframes slideUp {
            from {
                transform: translateY(100%);
            }
            to {
                transform: translateY(0);
            }
        }

        .modal-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 20px;
        }

        .modal-header h2 {
            font-size: 20px;
            color: #333;
        }

        .close-modal {
            background: none;
            border: none;
            font-size: 24px;
            cursor: pointer;
            color: #999;
        }

        .form-group {
            margin-bottom: 20px;
        }

        .form-group label {
            display: block;
            margin-bottom: 8px;
            color: #666;
            font-size: 14px;
        }

        .form-group select,
        .form-group input {
            width: 100%;
            padding: 12px;
            border: 1px solid #ddd;
            border-radius: 8px;
            font-size: 16px;
        }

        .btn-submit {
            width: 100%;
            padding: 14px;
            background: #007AFF;
            color: white;
            border: none;
            border-radius: 8px;
            font-size: 16px;
            font-weight: 500;
            cursor: pointer;
        }

        /* Нижняя навигация */
        .bottom-nav {
            position: fixed;
            bottom: 0;
            left: 0;
            right: 0;
            max-width: 400px;
            margin: 0 auto;
            display: flex;
            justify-content: space-around;
            padding: 10px 0;
            background: #fff;
            border-top: 1px solid #e0e0e0;
            z-index: 100;
        }

        .nav-item {
            display: flex;
            flex-direction: column;
            align-items: center;
            background: none;
            border: none;
            cursor: pointer;
            color: #999;
            font-size: 12px;
        }

        .nav-item.active {
            color: #007AFF;
        }

        .nav-item .icon {
            font-size: 20px;
            margin-bottom: 4px;
        }
    </style>
{% endblock %}

{% block body %}
    <div class="calendar-container">
        <div class="calendar-header">
            <div class="date-picker-header">
                <span class="selected-date" id="selectedDateDisplay">Выберите дату</span>
                <button class="view-all-btn" id="viewAllBtn">Все</button>
            </div>

            <div class="month-navigation">
                <button class="month-nav-btn" id="prevMonth">←</button>
                <span class="current-month" id="currentMonth">Март</span>
                <button class="month-nav-btn" id="nextMonth">→</button>
            </div>

            <!-- Дни недели -->
            <div class="weekdays">
                <span class="weekday">ПН</span>
                <span class="weekday">ВТ</span>
                <span class="weekday">СР</span>
                <span class="weekday">ЧТ</span>
                <span class="weekday">ПТ</span>
                <span class="weekday">Сб</span>
                <span class="weekday">ВС</span>
            </div>
        </div>

        <!-- Календарь -->
        <div class="calendar-grid" id="calendarGrid"></div>

        <!-- Записи на выбранную дату -->
        <div class="appointments-panel" id="appointmentsPanel">
            <div class="appointments-panel-header">
                <h3 id="appointmentsDateTitle">Записи на 22 марта</h3>
                <button class="add-appointment-btn" id="addAppointmentBtn">+ Добавить запись</button>
            </div>
            <div class="appointments-list" id="appointmentsList">
                <div class="no-appointments">Нет записей</div>
            </div>
        </div>

        <!-- Кнопка добавления клиента -->
        <button class="fab-add-client" id="fabAddClient">+</button>

        <!-- Нижняя навигация -->
        <div class="bottom-nav">
            <button class="nav-item" data-page="journal">
                <span class="icon">📋</span>
                <span>Журнал</span>
            </button>
            <button class="nav-item active" data-page="schedule">
                <span class="icon">📅</span>
                <span>График</span>
            </button>
            <button class="nav-item" data-page="clients">
                <span class="icon">👥</span>
                <span>Клиенты</span>
            </button>
            <button class="nav-item" data-page="notifications">
                <span class="icon">🔔</span>
                <span>Уведомление</span>
            </button>
            <button class="nav-item" data-page="more">
                <span class="icon">⋯</span>
                <span>Еще</span>
            </button>
        </div>
    </div>

    <!-- Модальное окно для добавления записи -->
    <div id="appointmentModal" class="modal">
        <div class="modal-content">
            <div class="modal-header">
                <h2>Новая запись</h2>
                <button class="close-modal">&times;</button>
            </div>
            <form id="appointmentForm">
                <div class="form-group">
                    <label for="clientSelect">Клиент:</label>
                    <select id="clientSelect" required>
                        <option value="">Выберите клиента</option>
                    </select>
                </div>
                <div class="form-group">
                    <label for="appointmentDate">Дата:</label>
                    <input type="date" id="appointmentDate" required>
                </div>
                <div class="form-group">
                    <label for="appointmentTime">Время:</label>
                    <select id="appointmentTime" required>
                        <option value="08:00">08:00 - 11:00</option>
                        <option value="09:00">09:00 - 12:00</option>
                        <option value="10:00">10:00 - 13:00</option>
                        <option value="11:00">11:00 - 14:00</option>
                        <option value="12:00">12:00 - 15:00</option>
                        <option value="13:00">13:00 - 16:00</option>
                        <option value="14:00">14:00 - 17:00</option>
                        <option value="15:00">15:00 - 18:00</option>
                        <option value="16:00">16:00 - 19:00</option>
                    </select>
                </div>
                <button type="submit" class="btn-submit">Создать запись</button>
            </form>
        </div>
    </div>

    <!-- Модальное окно для добавления клиента -->
    <div id="clientModal" class="modal">
        <div class="modal-content">
            <div class="modal-header">
                <h2>Новый клиент</h2>
                <button class="close-modal close-client">&times;</button>
            </div>
            <form id="newClientForm">
                <div class="form-group">
                    <label for="clientName">Имя:</label>
                    <input type="text" id="clientName" required>
                </div>
                <div class="form-group">
                    <label for="clientPhone">Телефон:</label>
                    <input type="tel" id="clientPhone" required placeholder="+7XXXXXXXXXX">
                </div>
                <button type="submit" class="btn-submit">Добавить клиента</button>
            </form>
        </div>
    </div>

    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <script>
        let currentDate = new Date();
        let selectedDate = new Date();
        let currentMonth = currentDate.getMonth();
        let currentYear = currentDate.getFullYear();
        let appointments = {};

        // Инициализация
        $(document).ready(function() {
            loadClients();
            loadAppointments();
            renderCalendar();

            // Обновление отображения выбранной даты
            updateSelectedDateDisplay();

            // Загрузка записей на выбранную дату
            loadAppointmentsForDate(selectedDate);

            // Обработчики событий
            $('#prevMonth').click(prevMonth);
            $('#nextMonth').click(nextMonth);
            $('#addAppointmentBtn').click(showAppointmentModal);
            $('#fabAddClient').click(showClientModal);
            $('#viewAllBtn').click(viewAllAppointments);

            // Закрытие модальных окон
            $('.close-modal, .close-client').click(function() {
                $('.modal').hide();
            });

            $(window).click(function(event) {
                if ($(event.target).hasClass('modal')) {
                    $('.modal').hide();
                }
            });

            // Отправка формы записи
            $('#appointmentForm').submit(createAppointment);

            // Отправка формы нового клиента
            $('#newClientForm').submit(createClient);

            // Навигация
            $('.nav-item').click(function() {
                const page = $(this).data('page');
                if (page === 'journal') {
                    window.location.href = '/';
                } else if (page === 'clients') {
                    window.location.href = '/clients';
                } else if (page === 'schedule') {
                    window.location.href = '/schedule';
                }
            });
        });

        // Загрузка списка клиентов
        function loadClients() {
            $.ajax({
                url: '/api/clients',
                method: 'GET',
                success: function(clients) {
                    const $select = $('#clientSelect');
                    $select.empty();
                    $select.append('<option value="">Выберите клиента</option>');
                    clients.forEach(client => {
                        $select.append(`<option value="${client.id}">${client.name} - ${client.phone}</option>`);
                    });
                }
            });
        }

        // Загрузка всех записей
        function loadAppointments() {
            $.ajax({
                url: '/api/appointments/all',
                method: 'GET',
                success: function(data) {
                    appointments = {};
                    data.forEach(apt => {
                        const date = apt.date;
                        if (!appointments[date]) {
                            appointments[date] = [];
                        }
                        appointments[date].push(apt);
                    });
                    renderCalendar();
                    loadAppointmentsForDate(selectedDate);
                }
            });
        }

        // Рендер календаря
        function renderCalendar() {
            const firstDay = new Date(currentYear, currentMonth, 1);
            const lastDay = new Date(currentYear, currentMonth + 1, 0);
            const startDayOfWeek = firstDay.getDay() || 7;
            const daysInMonth = lastDay.getDate();

            let calendarHtml = '';
            let dayCounter = 1;

            // Дни предыдущего месяца
            const prevMonthLastDay = new Date(currentYear, currentMonth, 0).getDate();
            for (let i = startDayOfWeek - 1; i > 0; i--) {
                const day = prevMonthLastDay - i + 1;
                calendarHtml += `<div class="calendar-day-cell other-month" data-date="${currentYear}-${currentMonth}-${day}">
                                <div class="day-number">${day}</div>
                            </div>`;
                dayCounter++;
            }

            // Дни текущего месяца
            const today = new Date();
            const todayStr = `${today.getFullYear()}-${today.getMonth()}-${today.getDate()}`;
            const selectedDateStr = `${selectedDate.getFullYear()}-${selectedDate.getMonth()}-${selectedDate.getDate()}`;

            for (let i = 1; i <= daysInMonth; i++) {
                const dateStr = `${currentYear}-${currentMonth}-${i}`;
                const hasAppointments = appointments[dateStr] && appointments[dateStr].length > 0;
                let additionalClass = '';

                if (currentYear === today.getFullYear() && currentMonth === today.getMonth() && i === today.getDate()) {
                    additionalClass = 'today';
                }

                if (dateStr === selectedDateStr) {
                    additionalClass = 'selected';
                }

                calendarHtml += `<div class="calendar-day-cell ${additionalClass} ${hasAppointments ? 'has-appointments' : ''}"
                                data-year="${currentYear}" data-month="${currentMonth}" data-day="${i}">
                                <div class="day-number">${i}</div>
                            </div>`;
            }

            // Дни следующего месяца
            const remainingCells = 42 - (dayCounter + daysInMonth - 1);
            for (let i = 1; i <= remainingCells; i++) {
                calendarHtml += `<div class="calendar-day-cell other-month" data-date="${currentYear}-${currentMonth + 1}-${i}">
                                <div class="day-number">${i}</div>
                            </div>`;
            }

            $('#calendarGrid').html(calendarHtml);

            // Обновление названия месяца
            const monthNames = ['Январь', 'Февраль', 'Март', 'Апрель', 'Май', 'Июнь', 'Июль', 'Август', 'Сентябрь', 'Октябрь', 'Ноябрь', 'Декабрь'];
            $('#currentMonth').text(monthNames[currentMonth]);

            // Обработчик клика по дню
            $('.calendar-day-cell').click(function() {
                if ($(this).hasClass('other-month')) return;

                const year = $(this).data('year');
                const month = $(this).data('month');
                const day = $(this).data('day');

                selectedDate = new Date(year, month, day);
                updateSelectedDateDisplay();
                loadAppointmentsForDate(selectedDate);

                // Обновление выделения
                $('.calendar-day-cell').removeClass('selected');
                $(this).addClass('selected');
            });
        }

        // Загрузка записей на выбранную дату
        function loadAppointmentsForDate(date) {
            const dateStr = `${date.getFullYear()}-${date.getMonth() + 1}-${date.getDate()}`;
            const formattedDate = `${date.getDate()} ${getMonthName(date.getMonth())}`;
            $('#appointmentsDateTitle').text(`Записи на ${formattedDate}`);

            const dayAppointments = appointments[dateStr] || [];

            if (dayAppointments.length === 0) {
                $('#appointmentsList').html('<div class="no-appointments">Нет записей</div>');
                return;
            }

            let html = '';
            dayAppointments.forEach(apt => {
                html += `
                <div class="appointment-item" data-id="${apt.id}">
                    <div class="appointment-time">${apt.start_time}</div>
                    <div class="appointment-info">
                        <div class="appointment-client">${apt.client_name}</div>
                        <div class="appointment-phone">${apt.client_phone}</div>
                    </div>
                    <button class="delete-appointment" onclick="deleteAppointment(${apt.id})">🗑</button>
                </div>
            `;
            });

            $('#appointmentsList').html(html);
        }

        // Обновление отображения выбранной даты
        function updateSelectedDateDisplay() {
            const day = selectedDate.getDate();
            const month = getMonthName(selectedDate.getMonth());
            $('#selectedDateDisplay').text(`${day} ${month}`);
        }

        // Получение названия месяца
        function getMonthName(month) {
            const months = ['января', 'февраля', 'марта', 'апреля', 'мая', 'июня', 'июля', 'августа', 'сентября', 'октября', 'ноября', 'декабря'];
            return months[month];
        }

        // Предыдущий месяц
        function prevMonth() {
            currentMonth--;
            if (currentMonth < 0) {
                currentMonth = 11;
                currentYear--;
            }
            renderCalendar();
        }

        // Следующий месяц
        function nextMonth() {
            currentMonth++;
            if (currentMonth > 11) {
                currentMonth = 0;
                currentYear++;
            }
            renderCalendar();
        }

        // Показать модальное окно записи
        function showAppointmentModal() {
            const year = selectedDate.getFullYear();
            const month = String(selectedDate.getMonth() + 1).padStart(2, '0');
            const day = String(selectedDate.getDate()).padStart(2, '0');
            $('#appointmentDate').val(`${year}-${month}-${day}`);
            $('#appointmentModal').show();
        }

        // Показать модальное окно клиента
        function showClientModal() {
            $('#clientModal').show();
        }

        // Просмотр всех записей
        function viewAllAppointments() {
            alert('Все записи будут отображены в журнале');
            window.location.href = '/';
        }

        // Создание записи
        function createAppointment(e) {
            e.preventDefault();

            const clientId = $('#clientSelect').val();
            const date = $('#appointmentDate').val();
            const time = $('#appointmentTime').val();

            if (!clientId) {
                alert('Выберите клиента');
                return;
            }

            $.ajax({
                url: '/api/appointments',
                method: 'POST',
                contentType: 'application/json',
                data: JSON.stringify({
                    client_id: clientId,
                    date: date,
                    start_time: time
                }),
                success: function() {
                    $('#appointmentModal').hide();
                    loadAppointments();
                    $('#appointmentForm')[0].reset();
                },
                error: function(xhr) {
                    alert('Ошибка: ' + xhr.responseJSON.error);
                }
            });
        }

        // Создание клиента
        function createClient(e) {
            e.preventDefault();

            const name = $('#clientName').val();
            const phone = $('#clientPhone').val();

            $.ajax({
                url: '/api/clients',
                method: 'POST',
                contentType: 'application/json',
                data: JSON.stringify({
                    name: name,
                    phone: phone
                }),
                success: function() {
                    $('#clientModal').hide();
                    loadClients();
                    $('#newClientForm')[0].reset();
                },
                error: function(xhr) {
                    alert('Ошибка: ' + xhr.responseJSON.error);
                }
            });
        }

        // Удаление записи
        window.deleteAppointment = function(id) {
            if (confirm('Удалить эту запись?')) {
                $.ajax({
                    url: `/api/appointments/${id}`,
                    method: 'DELETE',
                    success: function() {
                        loadAppointments();
                    }
                });
            }
        };
    </script>
{% endblock %}